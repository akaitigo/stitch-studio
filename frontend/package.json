{
  "name": "stitch-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "check-wasm": "test -f src/wasm-pkg/stitch_studio_wasm_bg.wasm || (echo 'Error: WASM module not built. Run: make wasm (from project root)' && exit 1)",
    "predev": "npm run check-wasm",
    "prebuild": "npm run check-wasm",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint src/",
    "format": "biome format --write src/",
    "test": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "oxlint": "^1.66.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  }
}
